# Lately I've been using Manjaro's ZSH config, so these are only a few
# extensions to that. This file needs to be included manually in Manjaro's
# default `.zshrc`, like so:
#
# if [[ -e ~/.zsh_ext ]]; then
#     source ~/.zsh_ext
# fi


alias reload!='. ~/.zshrc'
export EDITOR="emacsclient -r -a ''"

# Vterm <-> Emacs customizations
# -----------------------------------------------------------------------------
vterm_printf() {
    if [ -n "$TMUX" ] && ([ "${TERM%%-*}" = "tmux" ] || [ "${TERM%%-*}" = "screen" ]); then
        # Tell tmux to pass the escape sequences through
        printf "\ePtmux;\e\e]%s\007\e\\" "$1"
    elif [ "${TERM%%-*}" = "screen" ]; then
        # GNU screen (screen, screen-256color, screen-256color-bce)
        printf "\eP\e]%s\007\e\\" "$1"
    else
        printf "\e]%s\e\\" "$1"
    fi
}

vterm_prompt_end() {
    vterm_printf "51;A$(whoami)@$(hostname):$(pwd)"
}
setopt PROMPT_SUBST
PROMPT=$PROMPT'%{$(vterm_prompt_end)%}'

# Babashka tab completion
# -----------------------------------------------------------------------------

_bb_tasks() {
    local matches=(`bb tasks |tail -n +3 |cut -f1 -d ' '`)
    compadd -a matches
    _files # autocomplete filenames as well
}
compdef _bb_tasks bb

# Load local configuration
# -----------------------------------------------------------------------------

if [[ -a ~/.localrc ]]
then
    source ~/.localrc
fi
